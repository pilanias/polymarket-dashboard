# Polymarket Dashboard environment template
# Copy to `.env` and fill with your own secrets.

# --- Core server ---
NODE_ENV=development
PORT=4000

# --- Service routing (monorepo backend proxy targets) ---
BTC_TRADER_URL=http://localhost:3000
WEATHER_BOT_URL=http://localhost:3001

# --- Polymarket/CLOB credentials (REQUIRED for live trading + weather live exchange) ---
PRIVATE_KEY=
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=
FUNDER_ADDRESS=
CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137
SIGNATURE_TYPE=0
TRADING_MODE=paper

# --- Supabase (required for persistent trade + weather data) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Polygon / Chainlink feeds ---
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_RPC_URLS=
POLYGON_WSS_URL=
POLYGON_WSS_URLS=
CHAINLINK_BTC_USD_AGGREGATOR=0xAB594600376Ec9fD91F8e885dADF0CE036862dE0

# --- BTC market discovery / feed selection ---
PRICE_FEED=kraken
KRAKEN_REST_BASE_URL=https://api.kraken.com
KRAKEN_WS_URL=wss://ws.kraken.com
KRAKEN_PAIR=XXBTZUSD
COINBASE_SYMBOL=BTC-USD
COINBASE_REST_BASE_URL=https://api.exchange.coinbase.com
COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com
POLYMARKET_SLUG=
POLYMARKET_AUTO_SELECT_LATEST=true
POLYMARKET_SERIES_ID=10684
POLYMARKET_SERIES_SLUG=btc-up-or-down-5m
POLYMARKET_LIVE_WS_URL=wss://ws-live-data.polymarket.com
POLYMARKET_UP_LABEL=Up
POLYMARKET_DOWN_LABEL=Down

# --- Trading mode toggles ---
AUTO_START_TRADING=true
PAPER_TRADING_ENABLED=true
LIVE_TRADING_ENABLED=false
LIVE_ENV_GATE=
LIVE_MANAGE_ALL_POSITIONS=true
LIVE_ALLOW_MARKET_ORDERS=false
LIVE_POST_ONLY=true

# --- Sizing / risk controls ---
STARTING_BALANCE=1000
STAKE_PCT=0.08
MIN_TRADE_USD=25
MAX_TRADE_USD=250
MAX_DAILY_LOSS_USD=50
DAILY_LOSS_LIMIT=50
KILL_SWITCH_OVERRIDE_BUFFER_PCT=0.10
CIRCUIT_BREAKER_LOSSES=5
CIRCUIT_BREAKER_COOLDOWN_MS=300000

# --- Optional model/engine integrations ---
ANTHROPIC_API_KEY=
WEBHOOK_URL=
WEBHOOK_TYPE=slack

# --- Runtime / observability / storage ---
BTC_VERBOSE=false
DATA_DIR=./data
LIQ_SAMPLES_PATH=./data/liquidity-samples.ndjson
UI_PORT=8080
UI_TZ=America/Los_Angeles
HOST=0.0.0.0
POLL_INTERVAL_MS=1000

# --- Optional network proxy envs (used by btc/net/proxy.js) ---
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
http_proxy=
https_proxy=
all_proxy=

# --- Advanced BTC tuning (optional; safe defaults exist in code) ---
# Uncomment and tune only if you know exactly why.
# PAPER_CONTRACT_SIZE=100
# MIN_MODEL_MAX_PROB=0.53
# STRONG_PROB_THRESHOLD=0.60
# STRONG_EDGE_THRESHOLD=0.05
# MIN_SPREAD=0.0
# MAX_SPREAD=0.012
# MIN_LIQUIDITY=500
# WEEKDAYS_ONLY=false
# WEEKEND_MIN_LIQUIDITY=20000
# WEEKEND_MAX_SPREAD=0.008
# WEEKEND_MIN_MODEL_MAX_PROB=0.60
# TAKE_PROFIT_PNL_USD=15
# STOP_LOSS_PCT=0.20


# --- Full advanced override list discovered in code (all optional) ---
ALLOW_SUNDAY_AFTER_HOUR=
DYNAMIC_TRAILING_ENABLED=
